{
  "name": "avalon-remaster",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '@avalon/server' dev & bun run --filter '@avalon/web' dev",
    "dev:server": "bun run --filter '@avalon/server' dev",
    "dev:web": "bun run --filter '@avalon/web' dev",
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "test:e2e": "bun run --filter '@avalon/web' test:e2e",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bun run --filter '*' lint",
    "format": "prettier --write \"packages/**/*.{ts,svelte,json,md}\""
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "typescript": "^5.7.3"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
